{
  "name": "horojob",
  "version": "1.0.0",
  "description": "AI-Driven Career Navigation & Recruitment powered by Vocational Astrology",
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "test:rntl": "jest --config jest.rntl.config.cjs --runInBand",
    "coverage:core": "c8 --all --src src --extension .ts --extension .tsx --exclude \"src/**/*.test.ts\" --exclude \"src/**/*.test.tsx\" --exclude \"src/**/*.rntl.test.ts\" --exclude \"src/**/*.rntl.test.tsx\" --reporter=text-summary --reporter=lcov --reporter=json-summary --reports-dir coverage/core node --import tsx --test \"src/**/*.test.ts\"",
    "coverage:rntl": "jest --config jest.rntl.config.cjs --runInBand --coverage --coverageDirectory coverage/rntl --coverageReporters=text-summary --coverageReporters=lcov --coverageReporters=json-summary",
    "precoverage": "node -e \"require('fs').rmSync('coverage',{ recursive: true, force: true })\"",
    "coverage": "npm run coverage:core && npm run coverage:rntl",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run test:rntl",
    "skills:log": "node scripts/append-skills-log.mjs"
  },
  "dependencies": {
    "@expo/metro-runtime": "^6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.13.0",
    "@shopify/react-native-skia": "2.2.12",
    "expo": "^54.0.33",
    "expo-calendar": "~15.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "^15.0.8",
    "expo-notifications": "~0.32.16",
    "expo-status-bar": "~3.0.9",
    "lucide-react-native": "^0.575.0",
    "nativewind": "^4.2.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "2.28.0",
    "react-native-purchases": "^9.14.0",
    "react-native-reanimated": "4.1.1",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "^3.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "^54.0.10",
    "c8": "^11.0.0",
    "eslint": "^9.24.0",
    "globals": "^16.0.0",
    "jest-expo": "~54.0.17",
    "prettier": "^3.3.3",
    "react-test-renderer": "^19.1.0",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.30.1",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=22 <23"
  },
  "private": true
}
