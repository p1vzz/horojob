<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/widget_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/widget_variant_card_background"
  android:orientation="vertical"
  android:padding="14dp">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="top"
    android:orientation="horizontal">

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:orientation="horizontal">

      <TextView
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/widget_variant_icon_disc"
        android:gravity="center"
        android:text="☼"
        android:textColor="@color/widget_text_gold"
        android:textSize="14sp"
        android:textStyle="bold" />

      <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
          android:id="@+id/widget_medium_title"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="Today's Career Vibe"
          android:textColor="@color/widget_text_primary"
          android:textSize="22sp"
          android:textStyle="bold" />

        <TextView
          android:id="@+id/widget_medium_date"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginTop="1dp"
          android:text="Thursday, Mar 20"
          android:textColor="@color/widget_text_secondary"
          android:textSize="11sp" />
      </LinearLayout>
    </LinearLayout>

    <LinearLayout
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:gravity="end"
      android:orientation="vertical">

      <TextView
        android:id="@+id/widget_medium_delta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="+15%"
        android:textColor="@color/widget_trend_positive"
        android:textSize="33sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/widget_medium_trend"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="↗ Rising"
        android:textColor="@color/widget_trend_positive"
        android:textSize="12sp"
        android:textStyle="bold" />
    </LinearLayout>
  </LinearLayout>

  <TextView
    android:id="@+id/widget_medium_summary"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:ellipsize="end"
    android:maxLines="3"
    android:text="Mercury trines your natal Sun. Excellent for presentations, negotiations, and making lasting impressions."
    android:textColor="@color/widget_text_secondary"
    android:textSize="15sp"
    android:lineSpacingExtra="2dp" />
</LinearLayout>
