<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/widget_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/widget_variant_card_background"
  android:gravity="center_vertical"
  android:orientation="horizontal"
  android:paddingStart="10dp"
  android:paddingEnd="10dp"
  android:paddingTop="7dp"
  android:paddingBottom="7dp">

  <TextView
    android:layout_width="30dp"
    android:layout_height="30dp"
    android:background="@drawable/widget_variant_icon_disc"
    android:gravity="center"
    android:text="☀"
    android:textColor="@color/widget_text_gold"
    android:textSize="14sp"
    android:textStyle="bold" />

  <LinearLayout
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_weight="1"
    android:layout_marginStart="9dp"
    android:orientation="vertical">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center_vertical"
      android:orientation="horizontal">

      <TextView
        android:id="@+id/widget_strip_peak_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Career Vibe"
        android:textColor="@color/widget_text_primary"
        android:textSize="19sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/widget_strip_peak_delta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:background="@drawable/widget_variant_delta_badge"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:text="+15%"
        android:textColor="@color/widget_trend_positive"
        android:textSize="11sp"
        android:textStyle="bold" />
    </LinearLayout>

    <TextView
      android:id="@+id/widget_strip_peak_summary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:ellipsize="end"
      android:maxLines="1"
      android:text="Mercury trines Sun - great for presentations."
      android:textColor="@color/widget_text_secondary"
      android:textSize="12sp" />
  </LinearLayout>

  <LinearLayout
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginStart="8dp"
    android:gravity="end"
    android:orientation="vertical">

    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="Peak"
      android:textColor="@color/widget_text_muted"
      android:textSize="10sp" />

    <TextView
      android:id="@+id/widget_strip_peak_time"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="2-4 PM"
      android:textColor="@color/widget_text_gold"
      android:textSize="24sp"
      android:textStyle="bold" />
  </LinearLayout>
</LinearLayout>
