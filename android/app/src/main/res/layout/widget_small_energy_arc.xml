<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/widget_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/widget_variant_card_background"
  android:orientation="vertical"
  android:padding="10dp">

  <TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="⚡"
    android:textColor="@color/widget_text_gold"
    android:textSize="16sp"
    android:textStyle="bold" />

  <ProgressBar
    android:id="@+id/widget_energy_arc_progress"
    style="?android:attr/progressBarStyleHorizontal"
    android:layout_width="match_parent"
    android:layout_height="6dp"
    android:layout_marginTop="6dp"
    android:max="100"
    android:progress="72"
    android:progressDrawable="@drawable/widget_variant_meter" />

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1"
    android:gravity="center"
    android:orientation="vertical">

    <TextView
      android:id="@+id/widget_energy_arc_value"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="72"
      android:textColor="@color/widget_text_primary"
      android:textSize="38sp"
      android:textStyle="bold" />

    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="Energy Level"
      android:textColor="@color/widget_text_secondary"
      android:textSize="11sp" />
  </LinearLayout>

  <TextView
    android:id="@+id/widget_energy_arc_delta"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="+8 from yesterday"
    android:textColor="@color/widget_trend_positive"
    android:textSize="11sp"
    android:textStyle="bold" />
</LinearLayout>
