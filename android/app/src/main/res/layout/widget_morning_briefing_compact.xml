<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/widget_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/widget_briefing_background"
  android:orientation="vertical">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/widget_briefing_glass_strip"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingTop="7dp"
    android:paddingBottom="7dp"
    android:paddingStart="9dp"
    android:paddingEnd="9dp">

    <TextView
      android:id="@+id/widget_badge"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:background="@drawable/widget_briefing_badge_background"
      android:paddingTop="2dp"
      android:paddingBottom="2dp"
      android:paddingStart="7dp"
      android:paddingEnd="7dp"
      android:text="Briefing"
      android:textColor="#F7D890"
      android:textSize="9sp"
      android:textStyle="bold" />

    <TextView
      android:layout_width="0dp"
      android:layout_height="1dp"
      android:layout_weight="1"
      android:text="" />

    <TextView
      android:id="@+id/widget_mode_chip"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:background="@drawable/widget_briefing_mode_chip_background"
      android:ellipsize="end"
      android:maxLines="1"
      android:paddingTop="2dp"
      android:paddingBottom="2dp"
      android:paddingStart="7dp"
      android:paddingEnd="7dp"
      android:text="Mode"
      android:textColor="#E8E9F7"
      android:textSize="9sp"
      android:textStyle="bold" />
  </LinearLayout>

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:paddingStart="10dp"
    android:paddingEnd="10dp">

    <TextView
      android:id="@+id/widget_headline"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:ellipsize="end"
      android:maxLines="1"
      android:text="Morning Career Briefing"
      android:textColor="#ECECF9"
      android:textSize="14sp"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/widget_summary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="4dp"
      android:ellipsize="end"
      android:maxLines="1"
      android:text="Open Horojob and sync your latest insights."
      android:textColor="#D2D5E8"
      android:textSize="11sp" />

    <TextView
      android:id="@+id/widget_metrics"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="6dp"
      android:background="@drawable/widget_briefing_metrics_background"
      android:ellipsize="end"
      android:maxLines="1"
      android:paddingTop="3dp"
      android:paddingBottom="3dp"
      android:paddingStart="7dp"
      android:paddingEnd="7dp"
      android:text="Tap to open Horojob"
      android:textColor="#B9BED7"
      android:textSize="10sp" />
  </LinearLayout>
</LinearLayout>
