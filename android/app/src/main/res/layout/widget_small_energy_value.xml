<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/widget_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/widget_variant_card_background"
  android:gravity="center"
  android:orientation="vertical"
  android:padding="10dp">

  <TextView
    android:layout_width="34dp"
    android:layout_height="34dp"
    android:background="@drawable/widget_variant_icon_disc"
    android:gravity="center"
    android:text="☀"
    android:textColor="@color/widget_text_gold"
    android:textSize="16sp"
    android:textStyle="bold" />

  <TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:text="Career Energy"
    android:textColor="@color/widget_text_primary"
    android:textSize="15sp"
    android:textStyle="bold" />

  <TextView
    android:id="@+id/widget_energy_value_value"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="4dp"
    android:text="85 / 100"
    android:textColor="@color/widget_text_accent"
    android:textSize="34sp"
    android:textStyle="bold" />
</LinearLayout>
