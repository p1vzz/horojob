<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/widget_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/widget_variant_card_background"
  android:gravity="center_vertical"
  android:orientation="horizontal"
  android:paddingStart="10dp"
  android:paddingEnd="10dp"
  android:paddingTop="7dp"
  android:paddingBottom="7dp">

  <TextView
    android:layout_width="28dp"
    android:layout_height="28dp"
    android:background="@drawable/widget_variant_icon_disc"
    android:gravity="center"
    android:text="☀"
    android:textColor="@color/widget_text_gold"
    android:textSize="13sp"
    android:textStyle="bold" />

  <TextView
    android:id="@+id/widget_strip_minimal_title"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_weight="1"
    android:layout_marginStart="9dp"
    android:text="Career Vibe"
    android:textColor="@color/widget_text_primary"
    android:textSize="20sp"
    android:textStyle="bold" />

  <TextView
    android:id="@+id/widget_strip_minimal_delta"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="+15%"
    android:textColor="@color/widget_trend_positive"
    android:textSize="30sp"
    android:textStyle="bold" />

  <TextView
    android:id="@+id/widget_strip_minimal_time"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginStart="9dp"
    android:text="2-4 PM"
    android:textColor="@color/widget_text_muted"
    android:textSize="21sp"
    android:textStyle="bold" />
</LinearLayout>
