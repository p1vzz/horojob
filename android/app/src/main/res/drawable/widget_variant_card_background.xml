<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
  <item>
    <shape android:shape="rectangle">
      <corners android:radius="22dp" />
      <gradient
        android:angle="315"
        android:startColor="@color/widget_card_bg_start"
        android:endColor="@color/widget_card_bg_end" />
      <stroke
        android:width="1dp"
        android:color="@color/widget_card_stroke" />
    </shape>
  </item>
  <item
    android:right="-38dp"
    android:top="-40dp">
    <shape android:shape="oval">
      <size
        android:width="140dp"
        android:height="140dp" />
      <gradient
        android:type="radial"
        android:startColor="@color/widget_card_glow"
        android:endColor="#00000000"
        android:gradientRadius="74dp" />
    </shape>
  </item>
</layer-list>
