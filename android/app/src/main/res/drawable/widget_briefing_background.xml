<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
  <item>
    <shape android:shape="rectangle">
      <corners android:radius="22dp" />
      <gradient
        android:angle="315"
        android:startColor="@color/widget_briefing_bg_start"
        android:centerColor="@color/widget_briefing_bg_center"
        android:endColor="@color/widget_briefing_bg_end" />
      <stroke
        android:width="1dp"
        android:color="@color/widget_briefing_stroke" />
    </shape>
  </item>

  <item>
    <shape android:shape="rectangle">
      <corners android:radius="22dp" />
      <gradient
        android:angle="90"
        android:startColor="@color/widget_briefing_glass_start"
        android:centerColor="@color/widget_briefing_glass_mid"
        android:endColor="@color/widget_briefing_glass_end" />
    </shape>
  </item>

  <item
    android:right="-46dp"
    android:top="-58dp">
    <shape android:shape="oval">
      <size
        android:width="190dp"
        android:height="190dp" />
      <gradient
        android:centerX="0.6"
        android:centerY="0.4"
        android:endColor="@color/widget_briefing_glow_end"
        android:gradientRadius="98dp"
        android:startColor="@color/widget_briefing_glow_start"
        android:type="radial" />
    </shape>
  </item>
</layer-list>
