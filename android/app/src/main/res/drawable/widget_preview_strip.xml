<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
  <item>
    <shape android:shape="rectangle">
      <corners android:radius="14dp" />
      <gradient
        android:angle="315"
        android:startColor="@color/widget_card_bg_start"
        android:endColor="@color/widget_card_bg_end" />
      <stroke
        android:width="1dp"
        android:color="@color/widget_card_stroke" />
    </shape>
  </item>
  <item
    android:left="14dp"
    android:top="11dp"
    android:width="26dp"
    android:height="26dp">
    <shape android:shape="oval">
      <solid android:color="@color/widget_chip_bg" />
    </shape>
  </item>
  <item
    android:left="48dp"
    android:right="78dp"
    android:top="15dp"
    android:height="7dp">
    <shape android:shape="rectangle">
      <corners android:radius="4dp" />
      <solid android:color="@color/widget_progress_bg" />
    </shape>
  </item>
</layer-list>
