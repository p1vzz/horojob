<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
  <item>
    <shape android:shape="rectangle">
      <corners android:radius="18dp" />
      <gradient
        android:angle="315"
        android:startColor="@color/widget_card_bg_start"
        android:endColor="@color/widget_card_bg_end" />
      <stroke
        android:width="1dp"
        android:color="@color/widget_card_stroke" />
    </shape>
  </item>
  <item
    android:gravity="center"
    android:height="18dp"
    android:width="56dp">
    <shape android:shape="rectangle">
      <corners android:radius="8dp" />
      <solid android:color="@color/widget_chip_bg" />
    </shape>
  </item>
</layer-list>
